rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }
    function isVerified() {
      return isSignedIn();
    }
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    function incoming() {
      return request.resource.data;
    }
    function existing() {
      return resource.data;
    }
    function isOwner(examId) {
      return isSignedIn() && get(/databases/$(database)/documents/exams/$(examId)).data.teacherId == request.auth.uid;
    }

    // --- Exams ---
    function isValidExam(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() <= 200
          && data.teacherId == (resource == null ? request.auth.uid : resource.data.teacherId)
          && (data.get('description', '') is string && data.get('description', '').size() <= 1000)
          && (data.get('createdAt', request.time) == request.time || data.get('createdAt', request.time) is timestamp);
    }

    match /exams/{examId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn();
      
      allow create: if isVerified() && isValidExam(incoming()) && isValidId(examId);
      allow update: if isOwner(examId) && isValidExam(incoming())
                   && incoming().teacherId == existing().teacherId
                   && incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'updatedAt']);
      allow delete: if isOwner(examId);

      // --- Questions ---
      match /questions/{questionId} {
        allow read: if isSignedIn();
        allow write: if isOwner(examId);
      }

      // --- Submissions ---
      function isValidSubmission(data) {
        return data.examId == examId
            && data.studentName is string && data.studentName.size() > 0 && data.studentName.size() <= 100
            && data.status in ['pending', 'graded'];
      }

      match /submissions/{submissionId} {
        allow create: if isVerified() && isValidSubmission(incoming()) && isValidId(submissionId)
                     && incoming().status == 'pending'
                     && (incoming().studentId == request.auth.uid || isOwner(examId));
        
        allow read: if isVerified() && (resource.data.studentId == request.auth.uid || isOwner(examId));
        
        match /results/{resultId} {
          allow read: if isVerified() && (
            get(/databases/$(database)/documents/exams/$(examId)/submissions/$(submissionId)).data.studentId == request.auth.uid || 
            isOwner(examId)
          );
          allow write: if isOwner(examId);
        }
      }
    }
  }
}
